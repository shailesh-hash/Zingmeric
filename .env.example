NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgresql://algotrader:algotrader@localhost:5432/algotrader?schema=public
REDIS_URL=redis://localhost:6379

# Observability (OpenTelemetry traces + Prometheus metrics)
OBSERVABILITY_ENABLED=true
OTEL_SERVICE_NAME=algotrader
OTEL_SERVICE_VERSION=0.1.0
# Prometheus metrics exposed at GET http://localhost:3000/metrics
# Optional OTLP trace export (Jaeger, Grafana Tempo, OTel Collector)
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
